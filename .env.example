# Maui Garden Tour Map - Environment Configuration
# Copy this file to .env and fill in your values

# ======================
# Database Configuration
# ======================
DB_HOST=localhost
DB_NAME=garden_tour
DB_USER=your_db_user
DB_PASS=your_db_password

# ======================
# Google Maps API
# ======================
# Get your API key from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Map ID for AdvancedMarkerElement (optional)
# Create one at: https://console.cloud.google.com/google/maps-apis/studio/maps
# Leave empty to use DEMO_MAP_ID for development
GOOGLE_MAPS_MAP_ID=

# ======================
# SMTP Email Configuration
# ======================
# For Gmail: use smtp.gmail.com, port 587, and an App Password
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Maui Garden Tour

# ======================
# Admin Configuration
# ======================
ADMIN_USER=admin
# Generate hash with: php -r "echo password_hash('your_password', PASSWORD_DEFAULT);"
ADMIN_PASS_HASH=$2y$10$your_password_hash_here
# Contact email shown to users
ADMIN_EMAIL=admin@yourdomain.com

# ======================
# Application Settings
# ======================
# Full URL to your site (no trailing slash)
SITE_URL=https://yourdomain.com
# How long confirmation tokens are valid (in hours)
TOKEN_EXPIRY_HOURS=24
# Maximum image upload size in MB
MAX_IMAGE_SIZE_MB=5
